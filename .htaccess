# Security Headers for GitHub Pages (if using custom domain)
# Note: GitHub Pages doesn't support .htaccess, but keep for reference

# Content Security Policy (CSP)
# Header set Content-Security-Policy "default-src 'self'; script-src 'self' https://cdnjs.cloudflare.com; style-src 'self' https://cdnjs.cloudflare.com; img-src 'self' data: https:; font-src 'self' https://cdnjs.cloudflare.com;"

# X-Frame-Options
# Header set X-Frame-Options "DENY"

# X-Content-Type-Options
# Header set X-Content-Type-Options "nosniff"

# Referrer Policy
# Header set Referrer-Policy "strict-origin-when-cross-origin"

# Permissions Policy
# Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"

# For GitHub Pages, add these via meta tags in HTML instead
# <meta http-equiv="Content-Security-Policy" content="default-src 'self';">
# <meta http-equiv="X-Frame-Options" content="DENY">
# <meta http-equiv="X-Content-Type-Options" content="nosniff">